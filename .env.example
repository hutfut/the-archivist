# Database connection (used by backend and docker-compose)
DATABASE_URL=postgresql+asyncpg://notebooklm:notebooklm@localhost:5432/notebooklm
POSTGRES_USER=notebooklm
POSTGRES_PASSWORD=notebooklm
POSTGRES_DB=notebooklm

# File storage
UPLOAD_DIR=data/uploads
MAX_UPLOAD_BYTES=52428800  # 50 MB

# Embedding model (runs locally via sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM provider: "mock" (default) or "ollama" (requires running Ollama)
LLM_PROVIDER=mock
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# Retrieval tuning
RETRIEVAL_MODE=hybrid    # vector | keyword | hybrid
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATE_K=20
SIMILARITY_THRESHOLD=0.3

# Conversation context window (max messages sent to LLM)
MAX_HISTORY_MESSAGES=50

# Logging
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
