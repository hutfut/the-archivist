# Database connection (used by backend and docker-compose)
# Copy this file to .env before running: cp .env.example .env
DATABASE_URL=postgresql+asyncpg://notebooklm:changeme@localhost:5432/notebooklm
POSTGRES_USER=notebooklm
POSTGRES_PASSWORD=changeme
POSTGRES_DB=notebooklm

# File storage
UPLOAD_DIR=data/uploads
MAX_UPLOAD_BYTES=52428800  # 50 MB

# Embedding model (runs locally via sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM provider: "mock" (default), "ollama", or "anthropic"
LLM_PROVIDER=mock

# Ollama settings (only used when LLM_PROVIDER=ollama)
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic settings (only used when LLM_PROVIDER=anthropic)
# Get your API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Retrieval tuning
RETRIEVAL_MODE=hybrid    # vector | keyword | hybrid
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATE_K=20
SIMILARITY_THRESHOLD=0.3

# Conversation context window (max messages sent to LLM)
MAX_HISTORY_MESSAGES=50

# Logging
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
